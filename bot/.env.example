# Previsao
PREVISAO_API_BASE=https://app.previsao.io/api/v1
PREVISAO_API_KEY=put_your_previsao_api_key_here
PREVISAO_API_SECRET=put_your_previsao_api_secret_here

# Polymarket CLOB
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_PRIVATE_KEY=put_your_wallet_private_key_here
POLYMARKET_ADDRESS=put_your_polymarket_wallet_address_here
POLYMARKET_FUNDER=put_your_polymarket_funder_address_here
POLYMARKET_API_KEY=put_your_polymarket_api_key_here
POLYMARKET_API_SECRET=put_your_polymarket_api_secret_here
POLYMARKET_API_PASSPHRASE=put_your_polymarket_api_passphrase_here
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_CHAIN_ID=137

# Dashboard / shared state, optional but recommended
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
DASHBOARD_DATA_TOKEN=choose_a_long_random_token

# Bot safety defaults
BOT_ENABLE_WS=1
BOT_MAX_OPEN_ORDERS=1
BOT_QUOTE_BOTH_SIDES=0
BOT_MIN_SECONDS_LEFT_FLOOR=20
BOT_STATE_PATH=work/hedge_state.json
BOT_LOCK_PATH=work/bot.lock
BOT_STOP_PATH=work/STOP_BOT

# Trading limits
POLYMARKET_MIN_ORDER_SHARES=5
POLYMARKET_MIN_MARKET_BUY_USDC=1
POLYMARKET_MARKET_BUY_MAX_PRICE=0.99
POLYMARKET_HEDGE_SLIPPAGE=0.03
POLYMARKET_MIN_HEDGE_FILL_RATIO=0.98
POLYMARKET_HEDGE_CIRCUIT_BREAKER=0
PREVISAO_MIN_LIMIT_ORDER_SHARES=5
PREVISAO_MIN_MARKET_SELL_USDC=0.01

